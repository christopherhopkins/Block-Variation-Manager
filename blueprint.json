			"step": "runPHP",
			"code": "<?php\nrequire_once '/wordpress/wp-load.php';\n\nif ( get_page_by_path( 'bvm-demo', OBJECT, 'post' ) ) { return; }\n\n$content = <<<'HTML'\n<!-- wp:heading {\"level\":1} -->\n<h1 class=\"wp-block-heading\">Block Variation Manager — Demo</h1>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Select any block below, open the block sidebar, and look for the <strong>Variation</strong> panel. Save the block's attributes as a named variation, then insert that variation elsewhere — edits to the variation propagate to every instance while preserving manual overrides.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:kadence/advancedheading {\"uniqueID\":\"4_980168-2c\",\"markBorder\":\"\",\"markBorderStyles\":[{\"top\":[null,\"\",\"\"],\"right\":[null,\"\",\"\"],\"bottom\":[null,\"\",\"\"],\"left\":[null,\"\",\"\"],\"unit\":\"px\"}],\"tabletMarkBorderStyles\":[{\"top\":[null,\"\",\"\"],\"right\":[null,\"\",\"\"],\"bottom\":[null,\"\",\"\"],\"left\":[null,\"\",\"\"],\"unit\":\"px\"}],\"mobileMarkBorderStyles\":[{\"top\":[null,\"\",\"\"],\"right\":[null,\"\",\"\"],\"bottom\":[null,\"\",\"\"],\"left\":[null,\"\",\"\"],\"unit\":\"px\"}],\"colorClass\":\"theme-palette3\",\"htmlTag\":\"h2\",\"className\":\"kt-adv-heading\"} -->\n<h2 class=\"kt-adv-heading4_980168-2c kt-adv-heading wp-block-kadence-advancedheading has-theme-palette-3-color has-text-color\" data-kb-block=\"kb-adv-heading4_980168-2c\">A Kadence advanced heading</h2>\n<!-- /wp:kadence/advancedheading -->\n\n<!-- wp:kadence/rowlayout {\"uniqueID\":\"4_d54775-65\",\"colLayout\":\"equal\",\"bgColor\":\"#0f172a\",\"textColor\":\"#ffffff\",\"padding\":[40,\"\",40,\"\"],\"kbVersion\":2} -->\n<!-- wp:kadence/column {\"borderWidth\":[\"\",\"\",\"\",\"\"],\"uniqueID\":\"4_1c1bf9-62\",\"kbVersion\":2} -->\n<div class=\"wp-block-kadence-column kadence-column4_1c1bf9-62\"><div class=\"kt-inside-inner-col\"><!-- wp:paragraph {\"textColor\":\"white\"} -->\n<p class=\"has-white-color has-text-color\">Left column inside a Kadence Row Layout with a dark background.</p>\n<!-- /wp:paragraph --></div></div>\n<!-- /wp:kadence/column -->\n\n<!-- wp:kadence/column {\"id\":2,\"borderWidth\":[\"\",\"\",\"\",\"\"],\"uniqueID\":\"4_2a8eef-1c\",\"kbVersion\":2} -->\n<div class=\"wp-block-kadence-column kadence-column4_2a8eef-1c\"><div class=\"kt-inside-inner-col\"><!-- wp:paragraph {\"textColor\":\"white\"} -->\n<p class=\"has-white-color has-text-color\">Right column. Try saving the row as a variation.</p>\n<!-- /wp:paragraph --></div></div>\n<!-- /wp:kadence/column -->\n<!-- /wp:kadence/rowlayout -->\n\n<!-- wp:kadence/accordion {\"uniqueID\":\"4_7a2955-1c\",\"openPane\":1,\"contentBgColor\":\"#ffffff\",\"contentBorderStyle\":[{\"top\":[\"\",\"\",0],\"right\":[\"\",\"\",0],\"bottom\":[\"\",\"\",0],\"left\":[\"\",\"\",0],\"unit\":\"px\"}],\"titleStyles\":[{\"size\":[\"\",\"\",\"\"],\"sizeType\":\"px\",\"lineHeight\":[\"\",\"\",\"\"],\"lineType\":\"\",\"letterSpacing\":\"\",\"family\":\"\",\"google\":\"\",\"style\":\"\",\"weight\":\"\",\"variant\":\"\",\"subset\":\"\",\"loadGoogle\":true,\"padding\":[13,15,13,15],\"marginTop\":10,\"color\":\"#555555\",\"background\":\"#f2f2f2\",\"border\":[\"\",\"\",\"\",\"\"],\"borderRadius\":[\"\",\"\",\"\",\"\"],\"borderWidth\":[\"\",\"\",\"\",\"\"],\"colorHover\":\"#444444\",\"backgroundHover\":\"#eeeeee\",\"borderHover\":[\"\",\"\",\"\",\"\"],\"colorActive\":\"#ffffff\",\"backgroundActive\":\"#BE530B\",\"borderActive\":[\"\",\"\",\"\",\"\"],\"textTransform\":\"\"}],\"titleBorder\":[{\"top\":[\"#f2f2f2\",\"\",1],\"right\":[\"#f2f2f2\",\"\",1],\"bottom\":[\"#f2f2f2\",\"\",1],\"left\":[\"#f2f2f2\",\"\",1],\"unit\":\"px\"}],\"titleBorderHover\":[{\"top\":[\"#878787\",\"\",1],\"right\":[\"#878787\",\"\",1],\"bottom\":[\"#878787\",\"\",1],\"left\":[\"#878787\",\"\",1],\"unit\":\"px\"}],\"titleBorderActive\":[{\"top\":[\"#BE530B\",\"\",1],\"right\":[\"#BE530B\",\"\",1],\"bottom\":[\"#BE530B\",\"\",1],\"left\":[\"#BE530B\",\"\",1],\"unit\":\"px\"}],\"titleBorderRadius\":[6,6,6,6]} -->\n<div class=\"wp-block-kadence-accordion alignnone\"><div class=\"kt-accordion-wrap kt-accordion-id4_7a2955-1c kt-accordion-has-2-panes kt-active-pane-1 kt-accordion-block kt-pane-header-alignment-left kt-accodion-icon-style-basic kt-accodion-icon-side-right\" style=\"max-width:none\"><div class=\"kt-accordion-inner-wrap\" data-allow-multiple-open=\"false\" data-start-open=\"1\"><!-- wp:kadence/pane {\"uniqueID\":\"4_d1c125-1e\"} -->\n<div class=\"wp-block-kadence-pane kt-accordion-pane kt-accordion-pane-1 kt-pane4_d1c125-1e\"><div class=\"kt-accordion-header-wrap\"><button class=\"kt-blocks-accordion-header kt-acccordion-button-label-show\" type=\"button\"><span class=\"kt-blocks-accordion-title-wrap\"><span class=\"kt-blocks-accordion-title\"></span></span><span class=\"kt-blocks-accordion-icon-trigger\"></span></button></div><div class=\"kt-accordion-panel\"><div class=\"kt-accordion-panel-inner\"><!-- wp:paragraph -->\n<p>A reusable named preset of a block's attributes.</p>\n<!-- /wp:paragraph --></div></div></div>\n<!-- /wp:kadence/pane -->\n\n<!-- wp:kadence/pane {\"id\":2,\"uniqueID\":\"4_a106d6-97\"} -->\n<div class=\"wp-block-kadence-pane kt-accordion-pane kt-accordion-pane-2 kt-pane4_a106d6-97\"><div class=\"kt-accordion-header-wrap\"><button class=\"kt-blocks-accordion-header kt-acccordion-button-label-show\" type=\"button\"><span class=\"kt-blocks-accordion-title-wrap\"><span class=\"kt-blocks-accordion-title\"></span></span><span class=\"kt-blocks-accordion-icon-trigger\"></span></button></div><div class=\"kt-accordion-panel\"><div class=\"kt-accordion-panel-inner\"><!-- wp:paragraph -->\n<p>Editing the variation updates every instance whose user hasn't manually overridden that attribute.</p>\n<!-- /wp:paragraph --></div></div></div>\n<!-- /wp:kadence/pane --></div></div></div>\n<!-- /wp:kadence/accordion -->\n\n<!-- wp:kadence/image {\"id\":0,\"ratio\":\"square\",\"useRatio\":true,\"uniqueID\":\"4_e2a815-8d\",\"maskSvg\":\"blob2\",\"maskUrl\":\"\",\"className\":\"kb-image-mask-blob2\"} -->\n<figure class=\"wp-block-kadence-image kb-image4_e2a815-8d kb-image-is-ratio-size kb-image-mask-blob2\"><div class=\"kb-is-ratio-image kb-image-ratio-square\"><img src=\"https://picsum.photos/seed/bvm/800/800\" alt=\"\" class=\"kb-img\"/></div></figure>\n<!-- /wp:kadence/image -->\nHTML;\n\nwp_insert_post( [\n\t'post_title'   => 'Block Variation Manager — Demo',\n\t'post_name'    => 'bvm-demo',\n\t'post_status'  => 'publish',\n\t'post_type'    => 'post',\n\t'post_content' => $content,\n] );\n"
